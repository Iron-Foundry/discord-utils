# ---------------------------------------------------------------
# Required
# ---------------------------------------------------------------

DISCORD_TOKEN=
GUILD_ID=

# Must point to the same MongoDB instance as discord-server.
MONGO_URI=

# Role IDs for permission checks.
STAFF_ROLE_ID=
SENIOR_STAFF_ROLE_ID=

# ---------------------------------------------------------------
# Optional
# ---------------------------------------------------------------

# MongoDB database name. Must match discord-server. Defaults to "foundry".
MONGO_DB_NAME=

# Set to true to enable debug logging.
DEBUG_MODE=
